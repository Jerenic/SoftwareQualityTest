#!/usr/bin/env sh
set -eu

echo "Running Spotless before commit..."

if [ -x "./gradlew" ]; then
  ./gradlew --no-daemon spotlessApply spotlessCheck
elif [ -x "./gradlew.bat" ]; then
  ./gradlew.bat --no-daemon spotlessApply spotlessCheck
else
  echo "Gradle wrapper not found."
  exit 1
fi

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)
if [ -n "${STAGED_FILES}" ]; then
  echo "${STAGED_FILES}" | while IFS= read -r file; do
    if [ -e "$file" ]; then
      git add "$file"
    fi
  done
fi

echo "Spotless checks passed."
